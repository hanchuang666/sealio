{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sealio 图章工具",
  "version": "0.1.0",
  "identifier": "com.sealio.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Sealio 图章工具",
        "width": 1440,
        "height": 930,
        "minWidth": 1180,
        "minHeight": 760,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundColor": "#15171b"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "copyright": "Copyright © Sealio",
    "shortDescription": "Sealio 图章工具",
    "longDescription": "PDF 和图片图章放置工具",
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  }
}
